Qualtrics.SurveyEngine.addOnPageSubmit(function() {

    var qid = this.questionId;

    jQuery("#" + qid + " .ChoiceRow").each(function() {
        var row = jQuery(this);

        var rowLabel = row.find(".c1").text().trim();

        var selectedValue = parseInt( row.find("input[type=radio]:checked").val());

		Qualtrics.SurveyEngine.setEmbeddedData('Effort', selectedValue);
    });

});
